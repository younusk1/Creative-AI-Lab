# PostgreSQL (used by PostgreSQL and n8n)
POSTGRES_DB=creative_ai_lab
POSTGRES_USER=creative_ai
POSTGRES_PASSWORD=replace-with-a-long-unique-password
POSTGRES_PORT=5433

# Open WebUI
# Generate a long random value; do not commit the real .env file.
WEBUI_SECRET_KEY=replace-with-a-long-random-secret
OPEN_WEBUI_ENABLE_SIGNUP=true
OPEN_WEBUI_PORT=3000

# Ollama
OLLAMA_PORT=11434

# Adminer
ADMINER_PORT=8080

# n8n
# Generate a long random value; changing it can make existing n8n credentials unreadable.
N8N_ENCRYPTION_KEY=replace-with-a-long-random-secret
N8N_HOST=localhost
N8N_PORT=5679
N8N_PROTOCOL=http
N8N_EDITOR_BASE_URL=http://localhost:5679
GENERIC_TIMEZONE=Asia/Karachi
